# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production
PORT=8000

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# File Upload Settings
MAX_CONTENT_LENGTH=104857600  # 100MB in bytes
MAX_FILES_PER_REQUEST=50

# Tesseract OCR Path (optional - will auto-detect if not set)
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac example: /usr/local/bin/tesseract
# Linux example: /usr/bin/tesseract
TESSERACT_CMD=

# Database (if using database in future)
# DATABASE_URL=postgresql://user:password@localhost/customs_db

# Redis (if using caching in future)
# REDIS_URL=redis://localhost:6379/0

# API Keys (if integrating external services)
# OPENAI_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Session Configuration
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=7200  # 2 hours in seconds